# EduPlatform SQA E2E configuration.
# Copy values into your local environment or CI secrets. Do not commit real secrets.

EDUPLATFORM_BASE_URL=https://example-staging.eduplatform.test
EDUPLATFORM_WORKSPACE_ID=123
EDUPLATFORM_CONSUMER=example-consumer
EDUPLATFORM_ADMIN_USERNAME=sqa.admin@example.test
EDUPLATFORM_ADMIN_PASSWORD=replace-me
EDUPLATFORM_STUDENT_PASSWORD=ReplaceMe123!
EDUPLATFORM_TEACHER_PASSWORD=ReplaceMe123!
EDUPLATFORM_TEST_OFFERING_ID=456
EDUPLATFORM_TEST_COURSE_KEY=pre_quraan

# Creates a real published public course offering for the configured workspace.
# Default link mode creates a new Moodle course. Use existing plus a Moodle course ID when needed.
EDUPLATFORM_ENABLE_PUBLIC_COURSE_CREATE=false
EDUPLATFORM_PUBLIC_COURSE_TITLE=
EDUPLATFORM_PUBLIC_COURSE_LINK_MODE=create_new
EDUPLATFORM_PUBLIC_COURSE_MOODLE_COURSE_ID=
EDUPLATFORM_PUBLIC_COURSE_CAPACITY=12
EDUPLATFORM_PUBLIC_COURSE_TUITION_AMOUNT=0.00
EDUPLATFORM_PUBLIC_COURSE_CURRENCY=USD
EDUPLATFORM_PUBLIC_COURSE_START_DATE=
EDUPLATFORM_PUBLIC_COURSE_END_DATE=

# Recommended defaults for the first executable journey. Cleanup is reported first; delete is blocked for paid/issued audit records.
EDUPLATFORM_PAYMENT_MODE=manual
EDUPLATFORM_CLEANUP_MODE=archive
EDUPLATFORM_COMPLETION_MODE=skip-step

# Scheduled runner controls. Daily runs safe guard checks. Weekly live runs are blocked unless this is true.
EDUPLATFORM_SQA_ALLOW_LIVE_WEEKLY=false
EDUPLATFORM_SQA_WEEKLY_PHASES=

# Needed when tests call Moodle web services.
EDUPLATFORM_WS_TOKEN=replace-me

# Optional role splits; leave unset when one workspace admin has all required permissions.
EDUPLATFORM_FINANCE_USERNAME=
EDUPLATFORM_FINANCE_PASSWORD=
EDUPLATFORM_PARENT_USERNAME=
EDUPLATFORM_PARENT_PASSWORD=

# Optional completion fixture values when EDUPLATFORM_COMPLETION_MODE=skip-step.
EDUPLATFORM_TEST_COHORT_ID=0
EDUPLATFORM_TEST_LESSON_ID=alphabet
EDUPLATFORM_TEST_UNIT_ID=alphabet
EDUPLATFORM_TEST_STEP_ID=lecture

# Must remain false/empty outside a deliberate, read-only production smoke.
EDUPLATFORM_ALLOW_PRODUCTION_E2E=false

# Creates a real public intake request. Use only against a controlled non-production workspace.
EDUPLATFORM_ENABLE_PUBLIC_INTAKE_SUBMIT=false

# Creates a real public intake request, loads it into admin student intake, and creates Moodle student/parent accounts.
EDUPLATFORM_ENABLE_ADMISSIONS_STUDENT_CREATE=false

# Creates a real public intake request, creates a student, requests course enrollment, and approves/syncs it.
EDUPLATFORM_ENABLE_COURSE_ENROLLMENT=false

# Creates a real student/enrollment, creates and issues a tuition invoice, and verifies admin billing visibility.
EDUPLATFORM_ENABLE_INVOICE_CREATE=false
EDUPLATFORM_INVOICE_LINE_AMOUNT=

# Creates a real student/enrollment/invoice, enters a published grade, and publishes the course grade.
EDUPLATFORM_ENABLE_CLASS_COMPLETION=false
EDUPLATFORM_COMPLETION_SCORE_PERCENT=95

# Creates a real completed student journey, previews transcript data, issues an official transcript, downloads it, and verifies it.
EDUPLATFORM_ENABLE_TRANSCRIPT_ISSUE=false

# Creates a real student/enrollment/invoice, records a manual payment, and verifies receipt plus paid/zero-balance status.
EDUPLATFORM_ENABLE_PAYMENT_RECEIPT=false

# Runs the full golden student journey: intake, student creation, enrollment, invoice, grade, transcript, payment, and receipt.
EDUPLATFORM_ENABLE_FULL_STUDENT_JOURNEY=false

# Creates a real public teacher application. Use only against a controlled non-production workspace.
EDUPLATFORM_ENABLE_TEACHER_INTAKE_SUBMIT=false

# Reserved for staged teacher onboarding. The full teacher journey flag below currently runs public submit, admin approval, teacher account/profile creation, and marketplace visibility.
EDUPLATFORM_ENABLE_TEACHER_ONBOARDING=false

# Runs the first golden teacher journey: public teacher application, admin approval, teacher onboarding/profile publishing, and marketplace verification.
EDUPLATFORM_ENABLE_FULL_TEACHER_JOURNEY=false

# Creates a teacher portal classroom fixture and exercises attendance, notes/homework, grade entry, and progress update as the teacher.
EDUPLATFORM_ENABLE_TEACHER_PORTAL_OPS=false

# Runs the full teacher golden path: public application, approval, teacher account/profile, marketplace, portal operations, reporting, and archive cleanup.
EDUPLATFORM_ENABLE_FULL_TEACHER_GOLDEN_PATH=false

# Creates a real parent/student fixture and verifies parent workspace, parent billing, and student-parent portal visibility.
EDUPLATFORM_ENABLE_PARENT_PORTAL_VISIBILITY=false

# Creates a real parent/student invoice, records payment, and verifies parent-visible paid invoice and receipt evidence.
EDUPLATFORM_ENABLE_PARENT_PAYMENT_VISIBILITY=false

# Runs a read-only admin smoke over workspace dashboard, operations links, people, offerings, invoices, and intake queues.
EDUPLATFORM_ENABLE_ADMIN_DASHBOARD_SMOKE=false

# Submits real public intake requests, rejects one, approve/loads one into Student Intake, and verifies status/audit evidence.
EDUPLATFORM_ENABLE_ADMISSIONS_OPERATIONS=false

# Creates, updates, publishes, archives a real course offering, and reviews a generated enrollment request.
EDUPLATFORM_ENABLE_COURSE_OFFERING_OPERATIONS=false

# Creates a real invoice/payment fixture and validates finance dashboard, payment policy, receipts, and parent billing visibility.
EDUPLATFORM_ENABLE_FINANCE_OPERATIONS=false

# Verifies managed reports, finance audit, transcript readiness/policy audit, and CSV evidence exports.
EDUPLATFORM_ENABLE_REPORTING_AUDIT_OPERATIONS=false

# Creates parent/teacher communications records and validates support inbox, reports, audit, notification diagnostics, and CSV evidence.
EDUPLATFORM_ENABLE_SUPPORT_COMMUNICATIONS=false

# Creates an academic offering/material fixture and validates student/teacher course content visibility.
EDUPLATFORM_ENABLE_ACADEMIC_CONTENT_VISIBILITY=false

# Creates an academic resource assignment, has the student complete it, records academic review, and verifies parent/admin evidence.
EDUPLATFORM_ENABLE_ACADEMIC_RESOURCE_LIFECYCLE=false

# Publishes an assignment grade and verifies teacher, student, parent, and admin transcript gradebook consistency.
EDUPLATFORM_ENABLE_ACADEMIC_GRADEBOOK_CONSISTENCY=false

# Records teacher attendance/progress and verifies admin audit/reporting plus student and parent visibility.
EDUPLATFORM_ENABLE_ACADEMIC_ATTENDANCE_PROGRESS_AUDIT=false

# Verifies missing grade, incomplete attendance, low-score/progress alert, and CSV export evidence controls.
EDUPLATFORM_ENABLE_ACADEMIC_QUALITY_CONTROLS=false

# Creates paired role fixtures and verifies student, parent, teacher, direct URL, and session access boundaries.
EDUPLATFORM_ENABLE_SECURITY_ACCESS_CONTROL=false

# Generates message, announcement, invoice, attendance, grade, and low-score notification events, then verifies notification center/email/log evidence.
EDUPLATFORM_ENABLE_NOTIFICATIONS_DELIVERY=false

# Verifies student record export, parent/guardian visibility, audit completeness, and CSV/PDF download integrity.
EDUPLATFORM_ENABLE_DATA_EXPORT_COMPLIANCE=false

# Archives generated SQA students, teachers, parents, invoices, course offerings, and materials, then verifies active queues hide them while audit/reporting retains evidence.
EDUPLATFORM_ENABLE_DATA_LIFECYCLE_CLEANUP=false

# Verifies rejected admissions, partial/failed payment states, incomplete transcript blocks, full-capacity enrollment blocks, and missing required-field validation.
EDUPLATFORM_ENABLE_FAILURE_WORKFLOW_CONTROLS=false

# Creates institution school SQA fixtures and verifies wholly owned branch operations inheritance plus independent franchise governance-only boundaries.
EDUPLATFORM_ENABLE_INSTITUTION_SCHOOL_MODELS=false

# Verifies branch admissions isolation, franchise-owned admissions, owned-branch revenue rollups, franchise finance separation, and child-school parent billing scope.
EDUPLATFORM_ENABLE_INSTITUTION_OPERATIONS_ISOLATION=false

# Verifies owned-school reporting rollups, franchise governance-only reporting, CSV/PDF school identifiers, and branded portal isolation.
EDUPLATFORM_ENABLE_INSTITUTION_REPORTING_BRANDING=false

# Verifies teacher/student school mobility, transfer audit updates, archived school active-queue hiding, and retained institution audit evidence.
EDUPLATFORM_ENABLE_INSTITUTION_MOBILITY_LIFECYCLE=false
# Verifies cross-school role boundaries, direct URL permission checks, and session workspace scope for institution school models.
EDUPLATFORM_ENABLE_INSTITUTION_SECURITY_MATRIX=false
# Verifies announcements, messages, support cases, notifications, and follow-up evidence stay scoped to the correct school.
EDUPLATFORM_ENABLE_INSTITUTION_COMMUNICATIONS_ISOLATION=false
# Verifies course offerings, resources, gradebook, attendance, and transcript records stay school-scoped.
EDUPLATFORM_ENABLE_INSTITUTION_ACADEMIC_ISOLATION=false
# Verifies final institution school readiness rollup, stale fixture hygiene, audit, and CSV export evidence.
EDUPLATFORM_ENABLE_INSTITUTION_READINESS_ROLLUP=false

# Creates one scoped student/parent/teacher/admin evidence set and verifies cross-role finance, academic, communication, security, compliance, and audit readiness.
EDUPLATFORM_ENABLE_CROSS_ROLE_GOLDEN_PATH=false

# Runs read-only dashboard load, report export, repeated session, and slow endpoint performance/reliability checks.
EDUPLATFORM_ENABLE_PERFORMANCE_RELIABILITY_SMOKE=false
EDUPLATFORM_PERFORMANCE_LOAD_THRESHOLD_MS=12000
EDUPLATFORM_PERFORMANCE_EXPORT_THRESHOLD_MS=15000
EDUPLATFORM_PERFORMANCE_ENDPOINT_THRESHOLD_MS=2500

# Creates a scoped teacher/student/parent fixture and checks admin, student, parent, and teacher pages at mobile widths with keyboard and label checks.
EDUPLATFORM_ENABLE_ACCESSIBILITY_RESPONSIVE_SMOKE=false

# Checks live BBB operations readiness without creating or joining a meeting.
EDUPLATFORM_ENABLE_LIVE_BBB_OPERATIONS_SMOKE=false

# Schedules and starts a provider-backed BBB session through the Moodle bridge. Use only in an approved live BBB test window.
EDUPLATFORM_ENABLE_LIVE_BBB_MEETING_LIFECYCLE=false

# Saves post-class attendance, parent-visible notes, follow-up, recording review, and diagnostics evidence after BBB bridge start.
EDUPLATFORM_ENABLE_LIVE_BBB_POST_CLASS_EVIDENCE=false

# Verifies student live schedule visibility, parent live hub, parent summaries, follow-up response, and BBB secret hygiene.
EDUPLATFORM_ENABLE_LIVE_BBB_STUDENT_PARENT_VISIBILITY=false

# Verifies parent trust audit, compliance review pack export, retention readiness, recording review, and BBB secret hygiene.
EDUPLATFORM_ENABLE_LIVE_BBB_TRUST_RETENTION_AUDIT=false

# Verifies live-session guide, Quraan materials, Virtual Tutor, Practice Coach, and learner-facing secret hygiene.
EDUPLATFORM_ENABLE_LIVE_BBB_INSTRUCTIONAL_READINESS=false

# Saves QA review, leadership case, improvement plan, and verifies quality analytics, reports, monitor evidence, and secret hygiene.
EDUPLATFORM_ENABLE_LIVE_BBB_QUALITY_LEADERSHIP=false

# Creates a recurring live BBB class series and verifies capacity planning, teacher directory/profile, student/parent schedule/calendar visibility, and secret hygiene.
EDUPLATFORM_ENABLE_LIVE_BBB_SCHEDULING_CAPACITY=false

# Cancels one generated session and then the remaining series, verifies active schedule hiding, direct join blocking, cancellation audit evidence, and secret hygiene.
EDUPLATFORM_ENABLE_LIVE_BBB_OPERATIONAL_RESILIENCE=false

# Records Backup/DR readiness evidence and verifies live BBB diagnostics, reports, and secret hygiene.
EDUPLATFORM_ENABLE_LIVE_BBB_BACKUP_DR_READINESS=false

# Verifies retention review workflow, intentionally blocked guarded purge, recovery evidence, and secret hygiene.
EDUPLATFORM_ENABLE_LIVE_BBB_RETENTION_CONTROLS=false

# Verifies teacher availability, student grouping consent, parent-link refresh/export, and BBB secret hygiene.
EDUPLATFORM_ENABLE_LIVE_BBB_CONSENT_GROUPING=false

# Verifies BBB phase 1-12 rollup evidence, no stale active generated SQA leftovers, and final readiness CSV export.
EDUPLATFORM_ENABLE_LIVE_BBB_PILOT_READINESS=false

# Optional token for exact live checksum comparison with local/hubredirect/deployment_drift_probe.php.
# If unset on the live server, the probe requires an authenticated site administrator session.
EDUPLATFORM_DEPLOYMENT_DRIFT_TOKEN=
EDUPLATFORM_HUBREDIRECT_DRIFT_PROBE_URL=
EDUPLATFORM_HUBREDIRECT_DRIFT_INCLUDE=
EDUPLATFORM_HUBREDIRECT_DRIFT_REQUIRE_PROBE=true

# Optional label for timestamped SQA evidence bundles under test-results/sqa-evidence-bundles.
EDUPLATFORM_EVIDENCE_BUNDLE_LABEL=eduplatform-sqa

# Phase 12 negative/control tests are local-only guard checks and do not need a live enable flag.
