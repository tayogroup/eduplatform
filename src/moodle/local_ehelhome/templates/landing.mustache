<div id="landing-root" class="pq-login-page">
  <style>
    :root {
      --pq-green: #15803d;
      --pq-ink: #173044;
      --pq-muted: #3f335f;
      --pq-purple: #c8b8ef;
      --pq-mint: #a7e0ba;
      --pq-peach: #ffcaad;
    }

    #landing-root,
    #landing-root * {
      box-sizing: border-box;
    }

    html,
    body {
      width: 100% !important;
      min-width: 100% !important;
      min-height: 100% !important;
      overflow: hidden !important;
    }

    #landing-root.pq-login-page {
      position: fixed !important;
      inset: 0 !important;
      z-index: 2147483000 !important;
      width: 100vw !important;
      min-width: 100vw !important;
      height: 100vh !important;
      min-height: 100vh !important;
      overflow: auto;
      font-family: system-ui, -apple-system, "Segoe UI", Arial, sans-serif;
      color: var(--pq-ink);
      background:
        radial-gradient(circle at top left, rgba(255, 202, 173, 0.48), transparent 32rem),
        radial-gradient(circle at bottom right, rgba(167, 224, 186, 0.42), transparent 34rem),
        linear-gradient(135deg, rgba(200, 184, 239, 0.88) 0%, rgba(167, 224, 186, 0.72) 100%);
    }

    #landing-root.pq-login-page::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      background-image: url("data:image/svg+xml,%3Csvg width='140' height='140' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23917aca' fill-opacity='0.14'%3E%3Ccircle cx='20' cy='20' r='6'/%3E%3Ccircle cx='70' cy='50' r='4'/%3E%3Ccircle cx='120' cy='20' r='5'/%3E%3Ccircle cx='40' cy='90' r='5'/%3E%3Ccircle cx='100' cy='110' r='6'/%3E%3Ccircle cx='20' cy='130' r='4'/%3E%3Ccircle cx='130' cy='80' r='5'/%3E%3Ccircle cx='80' cy='20' r='4'/%3E%3C/g%3E%3C/svg%3E");
      background-size: 140px 140px;
    }

    .pq-login-card {
      position: fixed !important;
      left: 50vw !important;
      top: 50vh !important;
      transform: translate(-50%, -50%) !important;
      width: min(34rem, calc(100vw - 48px));
      min-height: min(760px, calc(100vh - 48px));
      display: flex;
      align-items: center;
      justify-content: center;
      padding: clamp(2rem, 5vw, 3rem);
      border-radius: 22px;
      overflow: hidden;
      background: linear-gradient(135deg, var(--pq-purple) 0%, var(--pq-mint) 100%);
      box-shadow: 0 24px 62px rgba(23, 48, 68, 0.2);
    }

    .pq-login-card::before,
    .pq-login-card::after {
      content: "";
      position: absolute;
      border-radius: 999px;
      filter: blur(55px);
      opacity: 0.32;
      animation: pq-float 6s ease-in-out infinite;
    }

    .pq-login-card::before {
      width: 380px;
      height: 380px;
      top: -144px;
      left: -128px;
      background: var(--pq-peach);
    }

    .pq-login-card::after {
      width: 320px;
      height: 320px;
      right: -112px;
      bottom: -128px;
      background: #fff;
    }

    .pq-login-inner {
      position: relative;
      z-index: 1;
      width: min(100%, 25rem);
      display: grid;
      gap: 1.5rem;
    }

    .pq-login-logo {
      display: block;
      width: clamp(9rem, 24vw, 12rem);
      height: auto;
      margin: 0 auto;
      filter: drop-shadow(0 8px 14px rgba(23, 48, 68, 0.14));
    }

    .pq-login-copy {
      text-align: center;
    }

    .pq-login-title {
      margin: 0;
      color: var(--pq-green);
      font-size: clamp(1.65rem, 4vw, 2.05rem);
      line-height: 1.12;
      font-weight: 900;
    }

    .pq-login-subtitle,
    .pq-login-row,
    .pq-login-footer {
      color: var(--pq-muted);
      font-weight: 750;
      text-shadow: 0 1px 0 rgba(255, 255, 255, 0.32);
    }

    .pq-login-subtitle {
      margin: 0.85rem 0 0;
      font-size: 1rem;
    }

    .pq-login-form {
      display: grid;
      gap: 1rem;
    }

    .pq-login-label {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }

    .pq-login-input {
      width: 100%;
      min-height: 4rem;
      border: 1px solid rgba(23, 48, 68, 0.12);
      border-radius: 9px;
      padding: 0 1.55rem;
      background: #fffec9;
      color: #05080f;
      font: 700 1.05rem/1.2 system-ui, -apple-system, "Segoe UI", Arial, sans-serif;
      box-shadow: 0 3px 9px rgba(23, 48, 68, 0.12);
    }

    .pq-login-input:focus {
      outline: 0;
      border-color: rgba(255, 147, 107, 0.86);
      box-shadow: 0 0 0 4px rgba(255, 147, 107, 0.24), 0 3px 9px rgba(23, 48, 68, 0.12);
    }

    .pq-login-submit {
      width: 100%;
      min-height: 3.6rem;
      border: 0;
      border-radius: 9px;
      background: var(--pq-peach);
      color: #05080f;
      font: 850 1rem/1.2 system-ui, -apple-system, "Segoe UI", Arial, sans-serif;
      box-shadow: 0 10px 18px rgba(23, 48, 68, 0.12);
      cursor: pointer;
      transition: transform 0.16s ease, filter 0.16s ease;
    }

    .pq-login-submit:hover {
      filter: saturate(1.06) brightness(0.98);
      transform: translateY(-2px);
    }

    .pq-login-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      font-size: 0.82rem;
    }

    .pq-login-check {
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
    }

    .pq-login-check input {
      width: 1.1rem;
      height: 1.1rem;
      accent-color: #ff936b;
    }

    .pq-login-forgot {
      color: var(--pq-muted);
      text-decoration: none;
    }

    .pq-login-forgot:hover {
      text-decoration: underline;
    }

    .pq-login-footer {
      margin: 0;
      padding-top: 0.3rem;
      text-align: center;
      font-size: 0.82rem;
    }

    @keyframes pq-float {
      0%, 100% {
        transform: translateY(0);
      }
      50% {
        transform: translateY(-12px);
      }
    }

    @media (max-width: 520px) {
      .pq-login-card {
        width: 100vw;
        min-height: 100vh;
        border-radius: 0;
      }
    }
  </style>

  <main class="pq-login-card" aria-label="Ehel Quraan Academy login">
    <div class="pq-login-inner">
      <img
        src="{{{ config.wwwroot }}}/local/ehelhome/pix/ehelquraanacademy_logo.svg"
        alt="Ehel Quraan Academy logo"
        class="pq-login-logo"
      >

      <div class="pq-login-copy">
        <h1 class="pq-login-title">Welcome to Ehel Quraan Academy</h1>
        <p class="pq-login-subtitle">Sign in to continue your adventure!</p>
      </div>

      <form action="{{{ config.wwwroot }}}/login/index.php" method="post" class="pq-login-form">
        <input type="hidden" name="logintoken" value="{{logintoken}}">

        <label for="pq-login-username" class="pq-login-label">Username</label>
        <input
          id="pq-login-username"
          type="text"
          name="username"
          placeholder="Username"
          autocomplete="username"
          required
          class="pq-login-input"
        >

        <label for="pq-login-password" class="pq-login-label">Password</label>
        <input
          id="pq-login-password"
          type="password"
          name="password"
          placeholder="Password"
          autocomplete="current-password"
          required
          class="pq-login-input"
        >

        <button type="submit" class="pq-login-submit">Enter Classroom</button>

        <div class="pq-login-row">
          <label class="pq-login-check">
            <input type="checkbox" name="rememberusername">
            <span>Remember me</span>
          </label>
          <a href="{{{ config.wwwroot }}}/login/forgot_password.php" class="pq-login-forgot">Forgot?</a>
        </div>
      </form>

      <p class="pq-login-footer">&copy; 2026 Ehel Academy</p>
    </div>
  </main>
</div>
