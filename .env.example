# Copy to .env for local-only settings.
MOODLE_BASE_URL=
BUNNY_PULL_ZONE_URL=

# Bunny Storage deployment.
# Use the Storage Zone password/API key from the Bunny "FTP & API Access" tab.
BUNNY_STORAGE_ZONE=your-storage-zone-name
BUNNY_STORAGE_ACCESS_KEY=your-storage-zone-password
BUNNY_STORAGE_ENDPOINT=https://storage.bunnycdn.com

# Deployment paths. These must match the public base path used at build time.
BUNNY_DEPLOY_BASE_PATH_INTEGRATION=pre_quraan_integration
BUNNY_DEPLOY_BASE_PATH_STAGING=pre_quraan_staging
BUNNY_DEPLOY_BASE_PATH_PRODUCTION=pre_quraan

# Backward-compatible fallback used when a target-specific path is not set.
BUNNY_REMOTE_PREFIX=pre_quraan

# Optional non-interactive production confirmation for trusted CI only.
# BUNNY_DEPLOY_CONFIRM=DEPLOY PRODUCTION

# Optional local tooling for ElevenLabs audio generation.
# The production chatbot TTS key belongs in Moodle plugin settings, not static JS.
ELEVENLABS_API_KEY=your-elevenlabs-api-key
PREQURAN_QUIZ_TTS_VOICE_ID=B5xxC4eQoOFJnY4R5XkI
PREQURAN_QUIZ_TTS_MODEL_ID=eleven_multilingual_v2

# Optional local Somali international news video podcast for Samsung TV.
OPENAI_API_KEY=your-openai-api-key
OPENAI_NEWS_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
SOMALI_NEWS_TTS_PROVIDER=elevenlabs
SOMALI_NEWS_ELEVENLABS_VOICE_NAME=Ubax
SOMALI_NEWS_ELEVENLABS_VOICE_ID=your-ubax-elevenlabs-voice-id
SOMALI_NEWS_ELEVENLABS_MODEL_ID=eleven_multilingual_v2
SOMALI_NEWS_PORT=8787
SOMALI_NEWS_EVERY_MINUTES=180
FFMPEG_PATH=
