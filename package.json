{
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build:runtime": "node tools/build-unit-runtime-bundle.js alphabet",
    "build:bunny": "node tools/build-bunny-output.js all",
    "build:bunny:production": "node tools/build-bunny-output.js all --base-path=/pre_quraan/",
    "build:bunny:staging": "node tools/build-bunny-output.js all --base-path=/pre_quraan_staging/",
    "check:alphabet": "node tools/build-unit-runtime-bundle.js alphabet && node --check src/units/alphabet/unit.runtime.js && node --check src/shared/js/runtime/runtime.bundle.js",
    "create:unit": "node tools/create-unit.js",
    "deploy:bunny": "node tools/deploy-bunny-storage.js",
    "deploy:production": "node tools/deploy-bunny-storage.js --target=production",
    "deploy:production:dry-run": "node tools/deploy-bunny-storage.js --target=production --dry-run",
    "deploy:staging": "node tools/deploy-bunny-storage.js --target=staging",
    "deploy:staging:dry-run": "node tools/deploy-bunny-storage.js --target=staging --dry-run",
    "deploy:bunny:communications": "node tools/deploy-bunny-communications.js",
    "deploy:bunny:communications:dry": "node tools/deploy-bunny-communications.js --dry-run",
    "preview:bunny": "node tools/serve-bunny-output.js",
    "preview:bunny:production": "node tools/serve-bunny-output.js",
    "preview:bunny:staging": "node tools/serve-bunny-output.js",
    "env:local-dev": "npm run validate:units && npm run build:bunny:production && npm run verify:bunny:production",
    "env:local-unit": "npm run validate:units && npm run check:alphabet && npm run build:bunny:staging && npm run verify:bunny:staging",
    "env:staging": "npm run env:local-unit && npm run deploy:staging:dry-run",
    "env:production:dry-run": "npm run validate:units && npm run check:alphabet && npm run build:bunny:production && npm run verify:bunny:production && npm run deploy:production:dry-run",
    "normalize:unit": "node tools/normalize-unit-config.js alphabet",
    "test": "npm run check:alphabet",
    "validate:units": "node tools/validate-unit-config.js",
    "verify:bunny": "node tools/verify-bunny-output.js",
    "verify:bunny:production": "node tools/verify-bunny-output.js --base-path=/pre_quraan/",
    "verify:bunny:staging": "node tools/verify-bunny-output.js --base-path=/pre_quraan_staging/"
  },
  "devDependencies": {
    "vite": "^5.0.0"
  }
}
