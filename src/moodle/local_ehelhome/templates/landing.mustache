<div id="landing-root" class="eh-home">
  <style>
    :root {
      --eh-green: #176f43;
      --eh-green-dark: #0f3d2e;
      --eh-gold: #d99a26;
      --eh-ink: #162b35;
      --eh-muted: #5f6f75;
      --eh-line: rgba(22, 43, 53, 0.12);
      --eh-paper: #fffaf0;
      --eh-white: #ffffff;
    }

    #landing-root,
    #landing-root * {
      box-sizing: border-box;
    }

    html,
    body {
      margin: 0 !important;
      width: 100% !important;
      min-width: 100% !important;
      min-height: 100% !important;
      overflow: auto !important;
      background: var(--eh-paper) !important;
    }

    #landing-root.eh-home {
      position: relative;
      z-index: 2147483000;
      min-height: 100vh;
      overflow-x: hidden;
      font-family: system-ui, -apple-system, "Segoe UI", Arial, sans-serif;
      color: var(--eh-ink);
      background: var(--eh-paper);
    }

    .eh-home a {
      color: inherit;
      text-decoration: none;
    }

    .eh-shell {
      width: min(1180px, calc(100% - 32px));
      margin: 0 auto;
    }

    .eh-topbar {
      background: var(--eh-green-dark);
      color: rgba(255, 255, 255, 0.86);
      font-size: 0.82rem;
      font-weight: 700;
    }

    .eh-topbar .eh-shell {
      min-height: 38px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }

    .eh-topbar span {
      white-space: nowrap;
    }

    .eh-nav {
      position: sticky;
      top: 0;
      z-index: 10;
      background: rgba(255, 250, 240, 0.94);
      border-bottom: 1px solid var(--eh-line);
      backdrop-filter: blur(12px);
    }

    .eh-nav .eh-shell {
      min-height: 82px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }

    .eh-brand {
      display: inline-flex;
      align-items: center;
      gap: 0.85rem;
      min-width: 0;
    }

    .eh-brand img {
      width: 68px;
      height: auto;
      flex: 0 0 auto;
    }

    .eh-brand-name {
      display: block;
      color: var(--eh-green-dark);
      font-size: 1.08rem;
      line-height: 1.05;
      font-weight: 900;
    }

    .eh-brand-sub {
      display: block;
      margin-top: 0.18rem;
      color: var(--eh-muted);
      font-size: 0.78rem;
      font-weight: 800;
    }

    .eh-navlinks {
      display: flex;
      align-items: center;
      gap: 1.15rem;
      color: var(--eh-ink);
      font-size: 0.84rem;
      font-weight: 850;
    }

    .eh-navlinks a:hover {
      color: var(--eh-green);
    }

    .eh-btn,
    .eh-login-submit {
      display: inline-flex;
      min-height: 44px;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      border: 0;
      border-radius: 8px;
      padding: 0.78rem 1rem;
      font: 900 0.92rem/1 system-ui, -apple-system, "Segoe UI", Arial, sans-serif;
      cursor: pointer;
      transition: transform 0.16s ease, filter 0.16s ease, background 0.16s ease;
    }

    .eh-btn:hover,
    .eh-login-submit:hover {
      transform: translateY(-1px);
      filter: brightness(0.98);
    }

    .eh-btn-primary,
    .eh-login-submit {
      background: var(--eh-gold);
      color: #16110a;
      box-shadow: 0 12px 24px rgba(217, 154, 38, 0.24);
    }

    .eh-btn-dark {
      background: var(--eh-green);
      color: var(--eh-white);
      box-shadow: 0 12px 24px rgba(23, 111, 67, 0.2);
    }

    .eh-btn-light {
      background: var(--eh-gold);
      color: #16110a !important;
      border: 1px solid rgba(217, 154, 38, 0.34);
      box-shadow: 0 12px 24px rgba(217, 154, 38, 0.24);
      text-shadow: none;
    }

    .eh-hero {
      position: relative;
      min-height: min(760px, calc(100vh - 120px));
      display: grid;
      align-items: stretch;
      color: var(--eh-white);
      background: #0c231c url("{{{ config.wwwroot }}}/local/ehelhome/pix/landing-hero-quran.jpg") center / cover no-repeat;
    }

    .eh-hero::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, rgba(9, 29, 23, 0.9) 0%, rgba(9, 29, 23, 0.72) 48%, rgba(9, 29, 23, 0.3) 100%);
    }

    .eh-hero .eh-shell {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.58fr);
      gap: clamp(1.5rem, 4vw, 3.5rem);
      align-items: center;
      padding: clamp(3rem, 8vw, 5.5rem) 0;
    }

    .eh-kicker {
      display: inline-flex;
      width: fit-content;
      align-items: center;
      gap: 0.55rem;
      margin: 0 0 1.1rem;
      padding: 0.48rem 0.75rem;
      border: 1px solid rgba(255, 255, 255, 0.28);
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.12);
      color: rgba(255, 255, 255, 0.9);
      font-size: 0.76rem;
      font-weight: 900;
      text-transform: uppercase;
    }

    .eh-kicker::before {
      content: "";
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: var(--eh-gold);
    }

    .eh-hero h1 {
      max-width: 760px;
      margin: 0;
      color: var(--eh-white);
      font-size: clamp(2.8rem, 7vw, 5.6rem);
      line-height: 1.02;
      font-weight: 950;
      letter-spacing: 0;
      text-shadow: 0 6px 28px rgba(0, 0, 0, 0.34);
    }

    .eh-hero-copy {
      max-width: 630px;
      margin: 1.2rem 0 0;
      color: rgba(255, 255, 255, 0.88);
      font-size: clamp(1rem, 2vw, 1.2rem);
      line-height: 1.65;
      font-weight: 700;
    }

    .eh-hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.8rem;
      margin-top: 2rem;
    }

    .eh-login-panel {
      width: 100%;
      padding: 1.15rem;
      border: 1px solid rgba(255, 255, 255, 0.18);
      border-radius: 8px;
      background: rgba(255, 250, 240, 0.96);
      color: var(--eh-ink);
      box-shadow: 0 22px 60px rgba(0, 0, 0, 0.22);
    }

    .eh-login-panel h2 {
      margin: 0;
      color: var(--eh-green-dark);
      font-size: 1.25rem;
      line-height: 1.15;
      font-weight: 950;
    }

    .eh-login-panel p {
      margin: 0.42rem 0 1rem;
      color: var(--eh-muted);
      font-size: 0.9rem;
      line-height: 1.45;
      font-weight: 700;
    }

    .eh-alert {
      margin: 0 0 0.9rem;
      padding: 0.75rem;
      border-radius: 8px;
      background: #fff0d8;
      color: #6b3d00;
      font-size: 0.86rem;
      font-weight: 850;
    }

    .eh-login-form {
      display: grid;
      gap: 0.76rem;
    }

    .eh-login-label {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }

    .eh-login-input {
      width: 100%;
      min-height: 48px;
      border: 1px solid rgba(22, 43, 53, 0.16);
      border-radius: 8px;
      padding: 0 0.95rem;
      background: #fff;
      color: #0d1d24;
      font: 800 0.95rem/1.2 system-ui, -apple-system, "Segoe UI", Arial, sans-serif;
    }

    .eh-login-input:focus {
      outline: 0;
      border-color: var(--eh-gold);
      box-shadow: 0 0 0 4px rgba(217, 154, 38, 0.18);
    }

    .eh-login-submit {
      width: 100%;
      margin-top: 0.2rem;
    }

    .eh-login-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.8rem;
      color: var(--eh-muted);
      font-size: 0.8rem;
      font-weight: 800;
    }

    .eh-login-check {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
    }

    .eh-login-check input {
      width: 1rem;
      height: 1rem;
      accent-color: var(--eh-green);
    }

    .eh-login-row a:hover {
      color: var(--eh-green);
      text-decoration: underline;
    }

    .eh-section {
      padding: clamp(3.2rem, 7vw, 5rem) 0;
    }

    .eh-section-white {
      background: #fff;
    }

    .eh-section-head {
      max-width: 700px;
      margin-bottom: 2rem;
    }

    .eh-eyebrow {
      margin: 0 0 0.6rem;
      color: var(--eh-gold);
      font-size: 0.78rem;
      font-weight: 950;
      text-transform: uppercase;
    }

    .eh-section h2 {
      margin: 0;
      color: var(--eh-green-dark);
      font-size: clamp(1.8rem, 4vw, 2.8rem);
      line-height: 1.08;
      font-weight: 950;
    }

    .eh-section-intro {
      margin: 0.9rem 0 0;
      color: var(--eh-muted);
      font-size: 1rem;
      line-height: 1.7;
      font-weight: 700;
    }

    .eh-feature-grid,
    .eh-course-grid,
    .eh-path-grid {
      display: grid;
      gap: 1rem;
    }

    .eh-feature-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .eh-course-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .eh-path-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .eh-card,
    .eh-course,
    .eh-path {
      border: 1px solid var(--eh-line);
      border-radius: 8px;
      background: #fff;
      overflow: hidden;
    }

    .eh-card,
    .eh-path {
      padding: 1.15rem;
    }

    .eh-card-icon {
      width: 42px;
      height: 42px;
      display: grid;
      place-items: center;
      margin-bottom: 0.9rem;
      border-radius: 8px;
      background: rgba(23, 111, 67, 0.1);
      color: var(--eh-green);
      font-size: 1.25rem;
      font-weight: 950;
    }

    .eh-card h3,
    .eh-course h3,
    .eh-path h3 {
      margin: 0;
      color: var(--eh-green-dark);
      font-size: 1.02rem;
      line-height: 1.25;
      font-weight: 950;
    }

    .eh-card p,
    .eh-course p,
    .eh-path p {
      margin: 0.58rem 0 0;
      color: var(--eh-muted);
      font-size: 0.92rem;
      line-height: 1.58;
      font-weight: 650;
    }

    .eh-course img {
      display: block;
      width: 100%;
      aspect-ratio: 16 / 10;
      object-fit: cover;
      background: #e6e1d6;
    }

    .eh-course-body {
      padding: 1rem;
    }

    .eh-split {
      display: grid;
      grid-template-columns: minmax(280px, 0.9fr) minmax(0, 1fr);
      gap: clamp(1.4rem, 4vw, 3rem);
      align-items: center;
    }

    .eh-photo {
      width: 100%;
      aspect-ratio: 4 / 3;
      object-fit: cover;
      border-radius: 8px;
      box-shadow: 0 18px 50px rgba(22, 43, 53, 0.14);
    }

    .eh-list {
      display: grid;
      gap: 0.75rem;
      margin: 1.35rem 0 0;
      padding: 0;
      list-style: none;
    }

    .eh-list li {
      display: flex;
      gap: 0.65rem;
      color: var(--eh-ink);
      font-weight: 800;
      line-height: 1.45;
    }

    .eh-list li::before {
      content: "";
      width: 9px;
      height: 9px;
      flex: 0 0 auto;
      margin-top: 0.38rem;
      border-radius: 999px;
      background: var(--eh-gold);
    }

    .eh-cta {
      color: var(--eh-white);
      background: var(--eh-green-dark);
    }

    .eh-cta .eh-shell {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 1.25rem;
      align-items: center;
    }

    .eh-cta h2 {
      color: var(--eh-white);
    }

    .eh-cta p {
      max-width: 680px;
      margin: 0.7rem 0 0;
      color: rgba(255, 255, 255, 0.82);
      font-weight: 700;
      line-height: 1.65;
    }

    .eh-footer {
      padding: 1.4rem 0;
      color: rgba(255, 255, 255, 0.74);
      background: #081f18;
      font-size: 0.86rem;
      font-weight: 750;
    }

    .eh-footer .eh-shell {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
    }

    @media (max-width: 980px) {
      .eh-navlinks {
        display: none;
      }

      .eh-hero .eh-shell,
      .eh-split,
      .eh-cta .eh-shell {
        grid-template-columns: 1fr;
      }

      .eh-login-panel {
        max-width: 520px;
      }

      .eh-feature-grid,
      .eh-course-grid,
      .eh-path-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 640px) {
      .eh-shell {
        width: min(100% - 24px, 1180px);
      }

      .eh-topbar .eh-shell {
        justify-content: center;
      }

      .eh-topbar span:nth-child(2) {
        display: none;
      }

      .eh-nav .eh-shell {
        min-height: 72px;
      }

      .eh-brand img {
        width: 56px;
      }

      .eh-brand-name {
        font-size: 0.98rem;
      }

      .eh-hero {
        min-height: auto;
      }

      .eh-hero::before {
        background: rgba(9, 29, 23, 0.78);
      }

      .eh-hero-actions,
      .eh-login-row {
        align-items: stretch;
        flex-direction: column;
      }

      .eh-btn {
        width: 100%;
      }

      .eh-feature-grid,
      .eh-course-grid,
      .eh-path-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <div class="eh-topbar" aria-label="Academy contact bar">
    <div class="eh-shell">
      <span>Online Quran and Arabic learning for children, families, and institutions</span>
      <span>Live classes, student rooms, gamified practice, and parent visibility</span>
    </div>
  </div>

  <header class="eh-nav">
    <div class="eh-shell">
      <a class="eh-brand" href="#home" aria-label="{{ config.brandname }} home">
        <img src="{{{ config.brandlogo }}}" alt="{{ config.brandname }} logo">
      <span>
        <span class="eh-brand-name">{{ config.brandname }}</span>
        <span class="eh-brand-sub">{{ config.brandsubtitle }}</span>
      </span>
      </a>

      <nav class="eh-navlinks" aria-label="Landing page navigation">
        <a href="{{{ config.abouturl }}}">About</a>
        <a href="{{{ config.coursesurl }}}">Courses</a>
        <a href="{{{ config.liveurl }}}">Live Sessions</a>
        <a href="{{{ config.dashboardsurl }}}">Dashboards</a>
        <a href="{{{ config.reportsurl }}}">Reports</a>
        <a href="{{{ config.featuresurl }}}">Features</a>
        <a href="{{{ config.pricingurl }}}">Pricing</a>
        <a href="{{{ config.enrollurl }}}">Enroll</a>
        <a href="{{{ config.inquiryurl }}}">Inquiry</a>
        <a href="{{{ config.contacturl }}}">Contact</a>
      </nav>

    </div>
  </header>

  <main id="home">
    <section class="eh-hero" aria-label="{{ config.brandname }} introduction">
      <div class="eh-shell">
        <div>
          <p class="eh-kicker">{{ config.herokicker }}</p>
          <h1>{{ config.herotitle }}</h1>
          <p class="eh-hero-copy">
            {{ config.herocopy }}
          </p>
          <div class="eh-hero-actions">
            <a class="eh-btn eh-btn-primary" href="{{{ config.enrollurl }}}">Request Enrollment</a>
            <a class="eh-btn eh-btn-light" href="{{{ config.inquiryurl }}}">General Inquiry</a>
            <a class="eh-btn eh-btn-light" href="{{{ config.studentappurl }}}">Student Login</a>
            <a class="eh-btn eh-btn-light" href="{{{ config.dashboardurl }}}">Family Dashboard</a>
          </div>
        </div>

        <aside class="eh-login-panel" aria-label="Academy login">
          <h2>Continue Learning</h2>
          <p>Sign in with your {{ config.brandname }} account to continue lessons, live sessions, homework, and progress review.</p>

          {{#sessionexpired}}
            <div class="eh-alert">Your session expired. Please sign in again to continue.</div>
          {{/sessionexpired}}

          <form action="{{{ config.loginurl }}}" method="post" class="eh-login-form">
            <input type="hidden" name="logintoken" value="{{logintoken}}">

            <label for="eh-login-username" class="eh-login-label">Username</label>
            <input
              id="eh-login-username"
              type="text"
              name="username"
              placeholder="Username"
              autocomplete="username"
              required
              class="eh-login-input"
            >

            <label for="eh-login-password" class="eh-login-label">Password</label>
            <input
              id="eh-login-password"
              type="password"
              name="password"
              placeholder="Password"
              autocomplete="current-password"
              required
              class="eh-login-input"
            >

            <button type="submit" class="eh-login-submit">Enter Classroom</button>

            <div class="eh-login-row">
              <label class="eh-login-check">
                <input type="checkbox" name="rememberusername">
                <span>Remember me</span>
              </label>
              <a href="{{{ config.forgoturl }}}">Forgot password?</a>
            </div>
          </form>
        </aside>
      </div>
    </section>

    <section class="eh-section eh-section-white" id="about">
      <div class="eh-shell">
        <div class="eh-section-head">
          <p class="eh-eyebrow">About the academy</p>
          <h2>A Quran learning environment built for children, families, institutions, and teachers</h2>
          <p class="eh-section-intro">
            {{ config.brandname }} helps children, families, and institutions learn Quran through a balanced model of live teaching, guided practice, supervised self-learning, and progress reporting. Our mission is to make Quran learning accessible, structured, safe, and motivating from home, school, masjid, or community setting. Our vision is to build a trusted online academy where every learner can grow in recitation, understanding, memorization, manners, and confidence.
          </p>
        </div>

        <div class="eh-feature-grid">
          <article class="eh-card">
            <div class="eh-card-icon">1</div>
            <h3>Advanced Teaching</h3>
            <p>Lessons combine teacher explanation, listening, repetition, guided practice, review, and age-appropriate feedback.</p>
            <p><a href="{{{ config.abouturl }}}">Read about the academy</a></p>
          </article>
          <article class="eh-card">
            <div class="eh-card-icon">2</div>
            <h3>Flexible Learning</h3>
            <p>Students can learn through live classes, offline assignments, student rooms, supervised self-learning, and practice coach support.</p>
            <p><a href="{{{ config.liveurl }}}">Explore live sessions</a></p>
          </article>
          <article class="eh-card">
            <div class="eh-card-icon">3</div>
            <h3>Privacy And Protection</h3>
            <p>Student access, family visibility, live-session controls, recordings, and communication are managed with care and safeguarding in mind.</p>
            <p><a href="{{{ config.featuresurl }}}">See academy features</a></p>
          </article>
          <article class="eh-card">
            <div class="eh-card-icon">4</div>
            <h3>Anywhere, Anytime</h3>
            <p>Families and institutions can continue learning with structured activities, gamified practice, media-rich lessons, teacher follow-up, and clear next steps.</p>
            <p><a href="{{{ config.dashboardsurl }}}">View dashboard capabilities</a></p>
          </article>
        </div>
      </div>
    </section>

    <section class="eh-section" id="courses">
      <div class="eh-shell">
        <div class="eh-section-head">
          <p class="eh-eyebrow">Learning paths</p>
          <h2>Courses for every stage of a child&apos;s Arabic and Quran journey</h2>
          <p class="eh-section-intro">
            Families and institutions can choose one course or combine courses as the learner grows. Each course is designed with clear goals, teacher guidance, practice activities, and progress visibility.
          </p>
        </div>

        <div class="eh-course-grid">
          <article class="eh-course">
            <img src="{{{ config.wwwroot }}}/local/ehelhome/pix/landing-course-qaida.jpg" alt="Child learning Quran foundations">
            <div class="eh-course-body">
              <h3>Pre-Quraan</h3>
              <p>Foundational Arabic letters, sounds, harakat, joining, listening, speaking, writing, and child-friendly practice for new learners.</p>
            </div>
          </article>
          <article class="eh-course">
            <img src="{{{ config.wwwroot }}}/local/ehelhome/pix/landing-welcome.jpg" alt="Children learning Islamic manners">
            <div class="eh-course-body">
              <h3>Tarbiyah Kids</h3>
              <p>Character, manners, daily Islamic values, family activities, stories, reflection, and supervised habits for young learners.</p>
            </div>
          </article>
          <article class="eh-course">
            <img src="{{{ config.wwwroot }}}/local/ehelhome/pix/landing-course-qaida.jpg" alt="Essential Arabic reading and writing course materials">
            <div class="eh-course-body">
              <h3>Essential Arabic</h3>
              <p>Basic Arabic reading, writing, vocabulary, sentence understanding, and comprehension for students building language confidence.</p>
            </div>
          </article>
          <article class="eh-course">
            <img src="{{{ config.wwwroot }}}/local/ehelhome/pix/landing-course-tajweed.jpg" alt="Quran reading course materials">
            <div class="eh-course-body">
              <h3>Quran Reading</h3>
              <p>Guided reading fluency, pronunciation, rhythm, tajweed readiness, passage practice, correction, and confidence building.</p>
            </div>
          </article>
          <article class="eh-course">
            <img src="{{{ config.wwwroot }}}/local/ehelhome/pix/landing-course-qaida.jpg" alt="Quran tafsir learning">
            <div class="eh-course-body">
              <h3>Quran Tafsir</h3>
              <p>Age-appropriate Quran meanings, vocabulary, stories, discussion, reflection, and practical lessons for daily life.</p>
            </div>
          </article>
          <article class="eh-course">
            <img src="{{{ config.wwwroot }}}/local/ehelhome/pix/landing-course-tajweed.jpg" alt="Quran memorization support">
            <div class="eh-course-body">
              <h3>Quran Memorization</h3>
              <p>Surah targets, memorization plans, revision schedules, teacher listening, mistake tracking, and family-supported review.</p>
            </div>
          </article>
        </div>
        <div class="eh-hero-actions">
          <a class="eh-btn eh-btn-primary" href="{{{ config.coursesurl }}}">View All Courses</a>
