{
  "schemaVersion": "Ehel English Games v1.0",
  "grade": 2,
  "unit": 1,
  "title": "Welcome and Calendar Game Zone",
  "masteryScore": 2,
  "games": [
    {
      "id": "picture-match",
      "type": "choice",
      "icon": "images",
      "title": "Meaning Match",
      "skill": "Vocabulary",
      "description": "Match each unit word to its child-friendly meaning.",
      "rounds": [
        {
          "prompt": "Which word means a person you work or play with?",
          "choices": [
            "partner",
            "calendar",
            "birthday"
          ],
          "answer": "partner",
          "explanation": "A partner is a person you work or play with."
        },
        {
          "prompt": "Which word means a chart that shows days, weeks and months?",
          "choices": [
            "friend",
            "calendar",
            "picture"
          ],
          "answer": "calendar",
          "explanation": "A calendar helps us find days, weeks, months and dates."
        },
        {
          "prompt": "Which word means the day each year when you celebrate being born?",
          "choices": [
            "birthday",
            "goodbye",
            "week"
          ],
          "answer": "birthday",
          "explanation": "Your birthday comes once each year."
        }
      ]
    },
    {
      "id": "spelling-builder",
      "type": "spelling",
      "icon": "blocks",
      "title": "Spelling Builder",
      "skill": "Spelling",
      "description": "Choose letter tiles to build important unit words.",
      "rounds": [
        {
          "prompt": "Build the greeting word.",
          "clue": "You say it when you meet someone.",
          "answer": "hello"
        },
        {
          "prompt": "Build the friendship word.",
          "clue": "A person you know and like.",
          "answer": "friend"
        },
        {
          "prompt": "Build the calendar word.",
          "clue": "It shows days, weeks and months.",
          "answer": "calendar"
        }
      ]
    },
    {
      "id": "sentence-puzzle",
      "type": "sentence",
      "icon": "puzzle",
      "title": "Sentence Puzzle",
      "skill": "Sentence building",
      "description": "Put the words in order to make a complete sentence.",
      "rounds": [
        {
          "prompt": "Introduce Amal.",
          "tokens": [
            "Amal.",
            "is",
            "name",
            "My"
          ],
          "answer": "My name is Amal."
        },
        {
          "prompt": "Tell what she enjoys.",
          "tokens": [
            "drawing.",
            "likes",
            "She"
          ],
          "answer": "She likes drawing."
        },
        {
          "prompt": "Ask a complete colour question.",
          "tokens": [
            "your",
            "What",
            "bag?",
            "is",
            "colour"
          ],
          "answer": "What colour is your bag?"
        }
      ]
    },
    {
      "id": "grammar-sort",
      "type": "choice",
      "icon": "list-filter",
      "title": "Grammar Sort",
      "skill": "Grammar",
      "description": "Choose the form that makes each sentence correct.",
      "rounds": [
        {
          "prompt": "This is Amal. ___ likes reading.",
          "choices": [
            "She",
            "He",
            "They"
          ],
          "answer": "She",
          "explanation": "Use she when talking about one girl or woman."
        },
        {
          "prompt": "Leo ___ football.",
          "choices": [
            "like",
            "likes",
            "liking"
          ],
          "answer": "likes",
          "explanation": "Use likes with he, she or one named person."
        },
        {
          "prompt": "Choose the complete question.",
          "choices": [
            "What colour is your bag?",
            "Your bag colour.",
            "How colour bag?"
          ],
          "answer": "What colour is your bag?",
          "explanation": "The complete pattern is: What colour is ...?"
        }
      ]
    },
    {
      "id": "reading-detective",
      "type": "choice",
      "icon": "scan-search",
      "title": "Reading Detective",
      "skill": "Comprehension",
      "description": "Use evidence from Amal's First Week to solve each clue.",
      "passage": "Amal met Leo on Saturday. Leo became her first partner. He likes football and mangoes, and his birthday is in June. On Thursday, Amal welcomed Nora and offered to be her partner.",
      "rounds": [
        {
          "prompt": "Who was Amal's first partner?",
          "choices": [
            "Leo",
            "Nora",
            "Teacher Yasmin"
          ],
          "answer": "Leo",
          "explanation": "The story says that Leo offered to be Amal's partner."
        },
        {
          "prompt": "When is Leo's birthday?",
          "choices": [
            "June",
            "December",
            "Saturday"
          ],
          "answer": "June",
          "explanation": "Leo says that his birthday is in June."
        },
        {
          "prompt": "How did Amal help Nora?",
          "choices": [
            "She welcomed her.",
            "She closed the door.",
            "She took her calendar."
          ],
          "answer": "She welcomed her.",
          "explanation": "Amal smiled, introduced herself and offered to be Nora's partner."
        }
      ]
    },
    {
      "id": "speaking-challenge",
      "type": "speaking",
      "icon": "mic-2",
      "title": "Speaking Quest",
      "skill": "Pronunciation",
      "description": "Listen, record, review and submit three useful sentences.",
      "rounds": [
        {
          "prompt": "Introduce yourself and say what you like.",
          "target": "My name is Amal. I like reading."
        },
        {
          "prompt": "Talk about a birthday month.",
          "target": "My birthday is in June."
        },
        {
          "prompt": "Welcome a new friend.",
          "target": "Hello. You can be my partner."
        }
      ]
    },
    {
      "id": "calendar-race",
      "type": "sequence",
      "icon": "calendar-days",
      "title": "Calendar Race",
      "skill": "Calendar order",
      "description": "Put days and months into the correct order before time runs out.",
      "rounds": [
        {
          "prompt": "Put these school-week days in order.",
          "tokens": [
            "Monday",
            "Saturday",
            "Sunday"
          ],
          "answer": "Saturday Sunday Monday"
        },
        {
          "prompt": "Put these middle-week days in order.",
          "tokens": [
            "Thursday",
            "Tuesday",
            "Wednesday"
          ],
          "answer": "Tuesday Wednesday Thursday"
        },
        {
          "prompt": "Put these months in calendar order.",
          "tokens": [
            "March",
            "January",
            "February"
          ],
          "answer": "January February March"
        }
      ]
    },
    {
      "id": "colour-number-dash",
      "type": "choice",
      "icon": "palette",
      "title": "Colour and Number Dash",
      "skill": "Colours and numbers",
      "description": "Choose the correct colour or number word in each fast challenge.",
      "rounds": [
        {
          "prompt": "Which word names the colour of grass?",
          "choices": [
            "green",
            "purple",
            "orange"
          ],
          "answer": "green",
          "explanation": "Grass is commonly described as green."
        },
        {
          "prompt": "Which number comes after eleven?",
          "choices": [
            "twelve",
            "ten",
            "twenty"
          ],
          "answer": "twelve",
          "explanation": "The counting order ends this unit with eleven, twelve."
        },
        {
          "prompt": "Which spelling names the colour of the sky on a clear day?",
          "choices": [
            "blue",
            "blew",
            "blu"
          ],
          "answer": "blue",
          "explanation": "Blue is the colour word."
        }
      ]
    },
    {
      "id": "pronoun-power",
      "type": "choice",
      "icon": "users-round",
      "title": "Pronoun Power",
      "skill": "He and she",
      "description": "Choose he or she to introduce each person clearly.",
      "rounds": [
        {
          "prompt": "This is Hannah. ___ likes trees.",
          "choices": [
            "She",
            "He",
            "It"
          ],
          "answer": "She",
          "explanation": "Use she for Hannah in this unit dialogue."
        },
        {
          "prompt": "This is Leo. ___ likes football.",
          "choices": [
            "He",
            "She",
            "We"
          ],
          "answer": "He",
          "explanation": "Use he for Leo in the story."
        },
        {
          "prompt": "This is Teacher Yasmin. ___ welcomes Amal.",
          "choices": [
            "She",
            "He",
            "They"
          ],
          "answer": "She",
          "explanation": "The story uses she for Teacher Yasmin."
        }
      ]
    },
    {
      "id": "memory-pairs",
      "type": "pairs",
      "icon": "copy-check",
      "title": "Memory Pairs",
      "skill": "Vocabulary recall",
      "description": "Turn over tiles and connect each word with its matching meaning.",
      "rounds": [
        {
          "prompt": "Match the greeting words.",
          "pairs": [
            [
              "hello",
              "a greeting"
            ],
            [
              "goodbye",
              "said when leaving"
            ],
            [
              "friend",
              "a person you know and like"
            ]
          ]
        },
        {
          "prompt": "Match the calendar words.",
          "pairs": [
            [
              "day",
              "one part of a week"
            ],
            [
              "month",
              "one part of a year"
            ],
            [
              "date",
              "a numbered day"
            ]
          ]
        },
        {
          "prompt": "Match the learning words.",
          "pairs": [
            [
              "book",
              "pages to read"
            ],
            [
              "picture",
              "an image to look at"
            ],
            [
              "word",
              "letters with meaning"
            ]
          ]
        }
      ]
    },
    {
      "id": "question-quest",
      "type": "sequence",
      "icon": "circle-help",
      "title": "Question Quest",
      "skill": "Question formation",
      "description": "Arrange words to build complete questions for a partner.",
      "rounds": [
        {
          "prompt": "Ask for a person's name.",
          "tokens": [
            "name?",
            "your",
            "is",
            "What"
          ],
          "answer": "What is your name?"
        },
        {
          "prompt": "Ask how to spell a name.",
          "tokens": [
            "spell",
            "you",
            "it?",
            "do",
            "How"
          ],
          "answer": "How do you spell it?"
        },
        {
          "prompt": "Ask what someone likes.",
          "tokens": [
            "like?",
            "you",
            "do",
            "What"
          ],
          "answer": "What do you like?"
        }
      ]
    },
    {
      "id": "welcome-mission",
      "type": "choice",
      "icon": "hand-heart",
      "title": "Welcome Mission",
      "skill": "Dialogue and kindness",
      "description": "Choose the best response to help a new classmate feel welcome.",
      "rounds": [
        {
          "prompt": "A new learner is standing by the door. What should you say first?",
          "choices": [
            "Hello. What is your name?",
            "Go away.",
            "Give me your book."
          ],
          "answer": "Hello. What is your name?",
          "explanation": "A friendly greeting helps a new learner feel welcome."
        },
        {
          "prompt": "The learner tells you her name. What is a kind next response?",
          "choices": [
            "You can be my partner.",
            "That is wrong.",
            "Do not sit here."
          ],
          "answer": "You can be my partner.",
          "explanation": "Offering to be a partner shows kindness and inclusion."
        },
        {
          "prompt": "Your new partner says, 'I like drawing.' What should you say?",
          "choices": [
            "I like drawing too!",
            "Be quiet.",
            "That is not a colour."
          ],
          "answer": "I like drawing too!",
          "explanation": "A relevant, friendly response keeps the dialogue going."
        }
      ]
    }
  ]
}
